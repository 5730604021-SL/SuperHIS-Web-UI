    "tags": [
     "Partners"
    ],
    "summary": "Get Partners",
    "description": "ดึงรายชื่อ Odoo Partner (res.partner) — ข้อมูลมาสดจาก Odoo ทุกครั้ง\nPartner ในที่นี้คือผู้ป่วยที่ถูก register เข้า Odoo แล้วผ่าน POST /partners/register/{hn}\nคืนเฉพาะ field: id, name, email, phone — default limit 10 รายการ (สูงสุด 50)\nใช้ id ที่ได้จาก response นี้เป็น partner_id ต่อใน Odoo workflow",
    "operationId": "list_partners",
    "parameters": [
     {
      "name": "limit",
      "in": "query",
      "required": false,
      "schema": {
       "type": "integer",
       "maximum": 50,
       "description": "จำนวนรายการสูงสุดที่คืนต่อครั้ง",
       "default": 10,
       "title": "Limit"
      },
      "description": "จำนวนรายการสูงสุดที่คืนต่อครั้ง"
     },
     {
      "name": "sort_by",
      "in": "query",
      "required": false,
      "schema": {
       "type": "string",
       "description": "field ที่ใช้ sort: email, id, name, phone",
       "default": "id",
       "title": "Sort By"
      },
      "description": "field ที่ใช้ sort: email, id, name, phone"
     },
     {
      "name": "sort_order",
      "in": "query",
      "required": false,
      "schema": {
       "enum": [
        "asc",
        "desc"
       ],
       "type": "string",
       "description": "ทิศทางการเรียง: asc = น้อยไปมาก, desc = มากไปน้อย",
       "default": "desc",
       "title": "Sort Order"
      },
      "description": "ทิศทางการเรียง: asc = น้อยไปมาก, desc = มากไปน้อย"
     }
    ],
    "responses": {
