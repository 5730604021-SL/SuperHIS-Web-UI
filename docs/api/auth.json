{
 "module": "auth",
 "note": "Extracted from SuperHIS FastAPI openapi.json. Base URL via Next proxy: /api/his",
 "paths": {
  "/auth/login": {
   "post": {
    "tags": [
     "Auth"
    ],
    "summary": "Login",
    "description": "login ด้วย username/password → ได้ Bearer token สำหรับส่งใน header\nAuthorization: Bearer <token> กับทุกคำขอ (อายุ token ตาม AUTH_SESSION_HOURS, default 12 ชม.)\nusername/password ผิดได้ 401, user หรือ staff เจ้าของถูกระงับได้ 403",
    "operationId": "login",
    "requestBody": {
     "content": {
      "application/json": {
       "schema": {
        "$ref": "#/components/schemas/LoginRequest"
       }
      }
     },
     "required": true
    },
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {}
       }
      }
     },
     "422": {
      "description": "Validation Error",
      "content": {
       "application/json": {
        "schema": {
         "$ref": "#/components/schemas/HTTPValidationError"
        }
       }
      }
     }
    },
    "security": []
   }
  },
  "/auth/me": {
   "get": {
    "tags": [
     "Auth"
    ],
    "summary": "Get Me",
    "description": "ข้อมูล user ที่ login อยู่ (จาก Bearer token) + role และ permissions —\nใช้เช็คว่า token ยังใช้ได้ไหม / ตอนนี้เป็นใคร",
    "operationId": "get_me",
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {}
       }
      }
     }
    },
    "security": [
     {
      "HTTPBearer": []
     }
    ]
   }
  },
  "/auth/logout": {
   "post": {
    "tags": [
     "Auth"
    ],
    "summary": "Logout",
    "description": "ออกจากระบบ — เพิกถอน session ปัจจุบัน (token ที่ส่งมา) ใช้ต่อไม่ได้ทันที",
    "operationId": "logout",
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {}
       }
      }
     }
    },
    "security": [
     {
      "HTTPBearer": []
     }
    ]
   }
  },
  "/auth/logout-all": {
   "post": {
    "tags": [
     "Auth"
    ],
    "summary": "Logout All",
    "description": "เพิกถอนทุก session ของ user ที่ login อยู่ (ทุกเครื่อง/ทุก token) —\nใช้เมื่อสงสัยว่า token หลุดหรือเปลี่ยนรหัสผ่านแล้วอยากตัด session เก่าทั้งหมด",
    "operationId": "logout_all",
    "responses": {
     "200": {
      "description": "Successful Response",
      "content": {
       "application/json": {
        "schema": {}
       }
      }
     }
    },
    "security": [
     {
      "HTTPBearer": []
     }
    ]
   }
  }
 },
 "schemas": {
  "HTTPValidationError": {
   "properties": {
    "detail": {
     "items": {
      "$ref": "#/components/schemas/ValidationError"
     },
     "type": "array",
     "title": "Detail"
    }
   },
   "type": "object",
   "title": "HTTPValidationError"
  },
  "LoginRequest": {
   "properties": {
    "username": {
     "type": "string",
     "title": "Username",
     "description": "ชื่อผู้ใช้ (ไม่สนตัวพิมพ์เล็ก/ใหญ่)"
    },
    "password": {
     "type": "string",
     "title": "Password",
     "description": "รหัสผ่าน"
    }
   },
   "type": "object",
   "required": [
    "username",
    "password"
   ],
   "title": "LoginRequest",
   "description": "login ด้วย username/password (user แบบ local) — user แบบ SSO ในอนาคตจะ login\nผ่าน endpoint ของ provider แทน ไม่ใช้เส้นนี้"
  },
  "ValidationError": {
   "properties": {
    "loc": {
     "items": {
      "anyOf": [
       {
        "type": "string"
       },
       {
        "type": "integer"
       }
      ]
     },
     "type": "array",
     "title": "Location"
    },
    "msg": {
     "type": "string",
     "title": "Message"
    },
    "type": {
     "type": "string",
     "title": "Error Type"
    },
    "input": {
     "title": "Input"
    },
    "ctx": {
     "type": "object",
     "title": "Context"
    }
   },
   "type": "object",
   "required": [
    "loc",
    "msg",
    "type"
   ],
   "title": "ValidationError"
  }
 }
}