     },
     {
      "name": "sort_by",
      "in": "query",
      "required": false,
      "schema": {
       "type": "string",
       "description": "field ที่ใช้ sort: agent_id, appointmentdate, body_temp, bp_diastolic, bp_systolic, checkout_date, createdate, heartrate, height, hn, nurse_id, respiratory_rate, status, visitdate, vn, weight",
       "default": "createdate",
       "title": "Sort By"
      },
      "description": "field ที่ใช้ sort: agent_id, appointmentdate, body_temp, bp_diastolic, bp_systolic, checkout_date, createdate, heartrate, height, hn, nurse_id, respiratory_rate, status, visitdate, vn, weight"
