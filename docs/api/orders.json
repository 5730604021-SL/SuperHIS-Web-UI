  "InvoiceCreateRequest": {
   "properties": {
    "order_id": {
     "type": "integer",
     "title": "Order Id",
     "description": "Odoo Sale Order ID"
    },
    "mode": {
     "type": "string",
     "enum": [
      "full",
      "down"
     ],
     "title": "Mode",
     "description": "full = ออกเต็มจำนวน, down = มัดจำ"
    },
    "amount": {
     "anyOf": [
      {
       "type": "number",
       "exclusiveMinimum": 0.0
      },
      {
       "type": "null"
      }
     ],
     "title": "Amount",
     "description": "มัดจำแบบระบุจำนวนเงิน (บาท)"
    },
    "amount_percent": {
     "anyOf": [
      {
       "type": "number",
       "maximum": 100.0,
       "exclusiveMinimum": 0.0
      },
      {
       "type": "null"
      }
     ],
     "title": "Amount Percent",
     "description": "มัดจำแบบ % (0–100)"
    }
   },
   "type": "object",
   "required": [
    "order_id",
    "mode"
   ],
   "title": "InvoiceCreateRequest"
  },
  "OrderCreateRequest": {
   "properties": {
    "hn": {
     "type": "string",
     "title": "Hn",
     "description": "รหัสผู้ป่วย (required)"
    },
    "partner_id": {
     "anyOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ],
     "title": "Partner Id",
     "description": "Odoo Partner ID (ถ้าไม่ใส่จะ search จาก HN)"
    },
    "vn": {
     "anyOf": [
      {
       "type": "string"
      },
      {
       "type": "null"
      }
     ],
     "title": "Vn"
    },
    "package_id": {
     "anyOf": [
      {
       "items": {
        "$ref": "#/components/schemas/PackageItem"
       },
       "type": "array"
      },
      {
       "type": "null"
      }
     ],
     "title": "Package Id"
    },
    "product_id": {
     "anyOf": [
      {
       "items": {
        "$ref": "#/components/schemas/ProductItem"
       },
       "type": "array"
      },
      {
       "type": "null"
      }
     ],
     "title": "Product Id"
    },
    "agent_id": {
     "anyOf": [
      {
       "type": "string"
      },
      {
       "type": "null"
      }
     ],
     "title": "Agent Id"
    },
    "is_vat": {
     "type": "boolean",
     "title": "Is Vat",
     "default": false
    },
    "is_service_charge": {
     "type": "boolean",
     "title": "Is Service Charge",
     "default": false
    },
    "medication_order_id": {
     "anyOf": [
      {
       "type": "string"
      },
      {
       "type": "null"
      }
     ],
     "title": "Medication Order Id",
     "description": "อ้างอิงใบสั่งยา (ถ้า order นี้คือการจ่ายยาตามใบสั่ง) — จะถูก stamp ลง patient_inventory ทุกแถวของ order นี้"
    },
    "doctor_code": {
     "anyOf": [
      {
       "type": "string"
      },
      {
       "type": "null"
      }
     ],
     "title": "Doctor Code",
     "description": "หมอเจ้าของ order (optional — order ไม่มีหมอก็สร้างได้)"
    },
    "df_amount": {
     "anyOf": [
      {
       "type": "number",
       "exclusiveMinimum": 0.0
      },
      {
       "type": "null"
      }
     ],
     "title": "Df Amount",
     "description": "ค่าแพทย์ (DF) ที่เก็บจากลูกค้าในบิลนี้ — ระบบใส่สินค้า DF 1 บาท × จำนวนนี้ให้เอง (ต้องระบุ doctor_code ด้วย) ใช้กับเคสขายขาด/ทำจบวันนั้น ส่วน DF ของคอร์สให้บันทึกผ่าน POST /df ตอนใช้"
    }
   },
   "type": "object",
   "required": [
    "hn"
   ],
   "title": "OrderCreateRequest"
  },
  "PackageItem": {
   "properties": {
    "id": {
     "type": "string",
     "title": "Id",
     "description": "รหัส Package / Course"
    },
    "quantity": {
     "type": "integer",
     "minimum": 1.0,
     "title": "Quantity",
     "description": "จำนวนชุด Package",
     "default": 1
    }
   },
   "type": "object",
   "required": [
    "id"
   ],
   "title": "PackageItem"
  },
  "ProductItem": {
   "properties": {
    "id": {
     "type": "integer",
     "title": "Id",
     "description": "Odoo product.product ID"
    },
    "quantity": {
     "type": "number",
     "exclusiveMinimum": 0.0,
     "title": "Quantity",
     "description": "จำนวนสินค้าใน 'หน่วยใช้จริง' (unit_of_use) — เช่น โบท็อกซ์ขวดละ 100cc ระบุเป็น cc (80 = 80cc), วิตามินขายเป็นกระปุกระบุจำนวนกระปุกตามปกติ (สินค้าที่ transfer_qty_coef=1 เลขเท่าหน่วย Odoo อยู่แล้ว) — ระบบแปลงเป็นหน่วยเก็บใน Odoo ให้เองตอนสร้าง order",
     "default": 1
    }
   },
   "type": "object",
   "required": [
    "id"
   ],
   "title": "ProductItem"
  },
  "ValidationError": {
   "properties": {
    "loc": {
     "items": {
      "anyOf": [
       {
        "type": "string"
       },
       {
        "type": "integer"
       }
      ]
     },
     "type": "array",
     "title": "Location"
    },
    "msg": {
     "type": "string",
     "title": "Message"
    },
    "type": {
     "type": "string",
     "title": "Error Type"
    },
    "input": {
     "title": "Input"
    },
    "ctx": {
     "type": "object",
     "title": "Context"
    }
   },
   "type": "object",
   "required": [
    "loc",
    "msg",
    "type"
   ],
   "title": "ValidationError"
  }
 }
}